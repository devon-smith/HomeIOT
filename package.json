{
  "name": "home-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first natural-language home control",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "discover": "tsx scripts/discover.ts",
    "sonos:list": "tsx scripts/list-sonos.ts",
    "test": "node --import tsx --test 'src/**/*.test.ts' 'scripts/**/*.test.ts'",
    "sonos": "tsx src/adapters/sonos/index.ts",
    "tv": "tsx src/adapters/tv/index.ts",
    "smoke": "tsx scripts/smoke.ts",
    "prisma": "prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/client": "^5.22.0",
    "bonjour-service": "^1.2.1",
    "bullmq": "^5.21.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "mqtt": "^5.10.1",
    "node-ssdp": "^4.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "sonos": "^1.14.3",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/node-ssdp": "^4.0.5",
    "@types/uuid": "^10.0.0",
    "aedes": "^1.0.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
