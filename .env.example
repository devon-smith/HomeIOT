NODE_ENV=development
LOG_LEVEL=debug
TZ=America/Los_Angeles

# HTTP
PORT=3000

# MQTT
MQTT_URL=mqtt://localhost:1883

# Postgres (matches docker-compose.yml host port)
DATABASE_URL=postgresql://home_brain:home_brain@localhost:5434/home_brain?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic — leave blank until Phase 1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# Discovery
DISCOVERY_TIMEOUT_MS=8000

# Voice surfaces (Alexa, Siri shortcut) sign every /interpret request with
# this shared secret. Generate with:  openssl rand -hex 32
# Leave blank to disable /interpret (the existing /message endpoint is
# unaffected — it stays Tailscale-only for now).
HB_HMAC_SECRET=
HB_HMAC_MAX_SKEW_MS=300000
HB_VOICE_DEADLINE_MS=6500

# Voice friction reduction (both default to ON when unset).
#   KEEP_OPEN keeps Alexa's session open after a command so you can chain
#             follow-ups without re-saying "Alexa, ask natasha brain to ...".
#   TERSE     collapses successful action confirmations to a short "OK." so
#             the user can talk again sooner. Query answers stay verbose.
HB_VOICE_KEEP_OPEN=true
HB_VOICE_TERSE=true

# Sonos playback defaults — applied on every "play X" the brain dispatches.
#   SHUFFLE  randomize track order
#   REPEAT   loop the queue forever when it ends
# Combined: shuffle+repeat -> SHUFFLE (default), shuffle only -> SHUFFLE_NOREPEAT,
# repeat only -> REPEAT_ALL, neither -> NORMAL.
HB_SONOS_SHUFFLE=true
HB_SONOS_REPEAT=true

# Claude API pricing (USD per million tokens) — Sonnet 4.6 defaults. The
# /api-usage page estimates spend with these.
HB_PRICE_INPUT_PER_MTOK=3.0
HB_PRICE_OUTPUT_PER_MTOK=15.0
HB_PRICE_CACHE_WRITE_PER_MTOK=3.75
HB_PRICE_CACHE_READ_PER_MTOK=0.30

# iAquaLink (cloud login — same as the iAquaLink mobile app)
IAQUALINK_EMAIL=
IAQUALINK_PASSWORD=

# Control4 (your Director controller's LAN IP + your C4 account)
# CONTROL4_HOST is the IP of the Director (HC800 / EA-5 / similar).
# Find it in the Control4 mobile app -> More -> System -> System Information.
CONTROL4_HOST=
CONTROL4_EMAIL=
CONTROL4_PASSWORD=
