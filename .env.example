NODE_ENV=development
LOG_LEVEL=debug
TZ=America/Los_Angeles

# HTTP
PORT=3000

# MQTT
MQTT_URL=mqtt://localhost:1883

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://home_brain:home_brain@localhost:5432/home_brain?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic — leave blank until Phase 1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# Discovery
DISCOVERY_TIMEOUT_MS=8000
